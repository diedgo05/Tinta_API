        {
          "name": "Delete Annotation",
          "request": { "method": "DELETE", "url": { "raw": "{{reading_url}}/api/v1/annotations/{{annotation_id}}", "host": ["{{reading_url}}"], "path": ["api","v1","annotations","{{annotation_id}}"] } }
