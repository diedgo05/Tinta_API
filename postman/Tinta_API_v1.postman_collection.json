    {
      "name": "9. Knowledge · Topics",
      "description": "Temas académicos disponibles para la base de conocimientos del LLM on-device.",
      "item": [
        {
          "name": "List All Topics (Public)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const j = pm.response.json();",
            "  if (j.items && j.items.length > 0) { pm.environment.set('topic_id', j.items[0].id); }",
            "}"
          ] } }],
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{knowledge_url}}/api/v1/topics", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics"] } }
        },
        {
          "name": "Get Topic by ID",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{knowledge_url}}/api/v1/topics/{{topic_id}}", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","{{topic_id}}"] } }
        },
        {
          "name": "Select My Topics (2-5)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"topic_ids\": [\n    \"{{topic_id}}\",\n    \"{{topic_id_2}}\"\n  ]\n}" },
            "url": { "raw": "{{knowledge_url}}/api/v1/topics/me", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","me"] }
          }
        },
        {
          "name": "List My Topics",
          "request": { "method": "GET", "url": { "raw": "{{knowledge_url}}/api/v1/topics/me", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","me"] } }
        },
        {
          "name": "Mark Topic as Downloaded",
          "request": { "method": "POST", "url": { "raw": "{{knowledge_url}}/api/v1/topics/me/{{topic_id}}/downloaded", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","me","{{topic_id}}","downloaded"] } }
        },
        {
          "name": "Remove Topic from My Selection",
          "request": { "method": "DELETE", "url": { "raw": "{{knowledge_url}}/api/v1/topics/me/{{topic_id}}", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","me","{{topic_id}}"] } }
        }
      ]
    },

    {
      "name": "10. Knowledge · Fragments (RAG)",
      "description": "Fragmentos descargables al celular. El celular consume estos endpoints al activar un tema.",
      "item": [
        {
          "name": "List Fragments by Topic",
          "request": { "method": "GET", "url": { "raw": "{{knowledge_url}}/api/v1/topics/{{topic_id}}/fragments?page=1&page_size=100", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","{{topic_id}}","fragments"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"100"}] } }
        },
        {
          "name": "List Documents by Topic",
          "request": { "method": "GET", "url": { "raw": "{{knowledge_url}}/api/v1/topics/{{topic_id}}/documents", "host": ["{{knowledge_url}}"], "path": ["api","v1","topics","{{topic_id}}","documents"] } }
        },
        {
          "name": "Create Document (Admin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) { pm.environment.set('document_id', pm.response.json().id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"topic_id\": \"{{topic_id}}\",\n  \"title\": \"Introducción a la Física\",\n  \"source\": \"openstax\",\n  \"license\": \"cc-by\",\n  \"url_original\": \"https://openstax.org/details/books/college-physics\"\n}" },
            "url": { "raw": "{{knowledge_url}}/api/v1/documents", "host": ["{{knowledge_url}}"], "path": ["api","v1","documents"] }
          }
        },
        {
          "name": "Create Fragment (Admin / Pipeline Python)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"document_id\": \"{{document_id}}\",\n  \"topic_id\": \"{{topic_id}}\",\n  \"text_chunk\": \"La segunda ley de Newton establece que la fuerza neta sobre un objeto es igual a su masa por su aceleración: F = ma.\",\n  \"position\": 0,\n  \"tokens\": 32,\n  \"embedding\": [0.012, -0.043, 0.521, 0.087],\n  \"hash_chunk\": \"sha256:abc123def456\"\n}" },
            "url": { "raw": "{{knowledge_url}}/api/v1/fragments", "host": ["{{knowledge_url}}"], "path": ["api","v1","fragments"] }
          }
        }
      ]
    },

    {
      "name": "11. Notifications",
      "item": [
        {
          "name": "List My Notifications",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const j = pm.response.json();",
            "  if (j.items && j.items.length > 0) { pm.environment.set('notification_id', j.items[0].id); }",
            "}"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{notifications_url}}/api/v1/notifications?page=1&page_size=20", "host": ["{{notifications_url}}"], "path": ["api","v1","notifications"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"},{"key":"unread","value":"false","description":"true para solo no leídas"}] } }
        },
        {
          "name": "List Unread Only",
          "request": { "method": "GET", "url": { "raw": "{{notifications_url}}/api/v1/notifications?unread=true", "host": ["{{notifications_url}}"], "path": ["api","v1","notifications"], "query": [{"key":"unread","value":"true"}] } }
        },
        {
          "name": "Create Notification (Admin/Internal)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) { pm.environment.set('notification_id', pm.response.json().id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"type\": \"reading_reminder\",\n  \"title\": \"¡Retoma tu lectura!\",\n  \"body\": \"Te quedan 5 capítulos para terminar Cien años de soledad.\",\n  \"data\": {\n    \"book_id\": \"{{book_id}}\"\n  }\n}" },
            "url": { "raw": "{{notifications_url}}/api/v1/notifications", "host": ["{{notifications_url}}"], "path": ["api","v1","notifications"] }
          }
        },
        {
          "name": "Mark as Read",
          "request": { "method": "POST", "url": { "raw": "{{notifications_url}}/api/v1/notifications/{{notification_id}}/read", "host": ["{{notifications_url}}"], "path": ["api","v1","notifications","{{notification_id}}","read"] } }
        },
        {
          "name": "Mark All as Read",
          "request": { "method": "POST", "url": { "raw": "{{notifications_url}}/api/v1/notifications/read-all", "host": ["{{notifications_url}}"], "path": ["api","v1","notifications","read-all"] } }
        },
        {
          "name": "Delete Notification",
          "request": { "method": "DELETE", "url": { "raw": "{{notifications_url}}/api/v1/notifications/{{notification_id}}", "host": ["{{notifications_url}}"], "path": ["api","v1","notifications","{{notification_id}}"] } }
        }
      ]
    }
  ]
}
