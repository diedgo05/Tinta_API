          "request": { "method": "GET", "url": { "raw": "{{reading_url}}/api/v1/annotations?book_id={{book_id}}", "host": ["{{reading_url}}"], "path": ["api","v1","annotations"], "query": [{"key":"book_id","value":"{{book_id}}"}] } }
