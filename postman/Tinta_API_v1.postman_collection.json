{
  "info": {
    "name": "Tinta API · v1 (Completa)",
    "description": "Colección completa con los 7 microservicios:\n\n- **Identity** (8001) — Auth, usuarios\n- **Community** (8002) — Clubes de lectura\n- **Recommendations** (8003) — Recomendaciones ML\n- **Catalog** (8004) — Libros y géneros ⭐\n- **Reading** (8005) — Progreso y anotaciones ⭐\n- **Knowledge** (8006) — Temas y fragmentos RAG ⭐\n- **Notifications** (8007) — Notificaciones in-app ⭐\n\nAuto-guarda tokens en el login. Usa el entorno 'Tinta Local' o 'Tinta Railway'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health Checks",
      "item": [
        { "name": "Identity",        "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{identity_url}}/health", "host": ["{{identity_url}}"], "path": ["health"] } } },
        { "name": "Community",       "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{community_url}}/health", "host": ["{{community_url}}"], "path": ["health"] } } },
        { "name": "Recommendations", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{recommendations_url}}/health", "host": ["{{recommendations_url}}"], "path": ["health"] } } },
        { "name": "Catalog",         "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{catalog_url}}/health", "host": ["{{catalog_url}}"], "path": ["health"] } } },
        { "name": "Reading",         "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{reading_url}}/health", "host": ["{{reading_url}}"], "path": ["health"] } } },
        { "name": "Knowledge",       "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{knowledge_url}}/health", "host": ["{{knowledge_url}}"], "path": ["health"] } } },
        { "name": "Notifications",   "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{notifications_url}}/health", "host": ["{{notifications_url}}"], "path": ["health"] } } }
      ]
    },

    {
      "name": "1. Auth (Identity)",
      "item": [
        {
          "name": "Login (Admin Adrian)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const j = pm.response.json();",
            "  pm.environment.set('access_token', j.access_token);",
            "  pm.environment.set('refresh_token', j.refresh_token);",
            "  console.log('✅ Tokens saved');",
            "}"
          ] } }],
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"adrian@tinta.app\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{identity_url}}/api/v1/auth/login", "host": ["{{identity_url}}"], "path": ["api","v1","auth","login"] }
          }
        },
        {
          "name": "Refresh Tokens",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const j = pm.response.json();",
            "  pm.environment.set('access_token', j.access_token);",
            "  pm.environment.set('refresh_token', j.refresh_token);",
            "}"
          ] } }],
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{identity_url}}/api/v1/auth/refresh", "host": ["{{identity_url}}"], "path": ["api","v1","auth","refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{identity_url}}/api/v1/auth/logout", "host": ["{{identity_url}}"], "path": ["api","v1","auth","logout"] }
          }
        }
      ]
    },

    {
      "name": "2. Users (Identity)",
      "item": [
        {
          "name": "Register (Public)",
          "request": {
            "auth": { "type": "noauth" }, "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@tinta.app\",\n  \"password\": \"test1234\",\n  \"name\": \"Test User\",\n  \"language\": \"es\"\n}" },
            "url": { "raw": "{{identity_url}}/api/v1/users", "host": ["{{identity_url}}"], "path": ["api","v1","users"] }
          }
        },
        {
          "name": "Get My Profile",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) { pm.environment.set('user_id', pm.response.json().id); }"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{identity_url}}/api/v1/users/me", "host": ["{{identity_url}}"], "path": ["api","v1","users","me"] } }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nombre actualizado\",\n  \"language\": \"es\"\n}" },
            "url": { "raw": "{{identity_url}}/api/v1/users/me", "host": ["{{identity_url}}"], "path": ["api","v1","users","me"] }
          }
        },
        {
          "name": "Delete My Account",
          "request": { "method": "DELETE", "url": { "raw": "{{identity_url}}/api/v1/users/me", "host": ["{{identity_url}}"], "path": ["api","v1","users","me"] } }
        }
      ]
    },

    {
      "name": "3. Clubs (Community)",
      "item": [
        {
          "name": "Create Club",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) { pm.environment.set('club_id', pm.response.json().id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Cien años de soledad\",\n  \"description\": \"Lectura colectiva del clásico\",\n  \"is_private\": false\n}" },
            "url": { "raw": "{{community_url}}/api/v1/clubs", "host": ["{{community_url}}"], "path": ["api","v1","clubs"] }
          }
        },
        {
          "name": "List Public Clubs",
          "request": { "method": "GET", "url": { "raw": "{{community_url}}/api/v1/clubs?page=1&page_size=20", "host": ["{{community_url}}"], "path": ["api","v1","clubs"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"}] } }
        },
        {
          "name": "Get Club by ID",
          "request": { "method": "GET", "url": { "raw": "{{community_url}}/api/v1/clubs/{{club_id}}", "host": ["{{community_url}}"], "path": ["api","v1","clubs","{{club_id}}"] } }
        },
        {
          "name": "Update Club",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Descripción actualizada\"\n}" },
            "url": { "raw": "{{community_url}}/api/v1/clubs/{{club_id}}", "host": ["{{community_url}}"], "path": ["api","v1","clubs","{{club_id}}"] }
          }
        },
        {
          "name": "Delete Club",
          "request": { "method": "DELETE", "url": { "raw": "{{community_url}}/api/v1/clubs/{{club_id}}", "host": ["{{community_url}}"], "path": ["api","v1","clubs","{{club_id}}"] } }
        }
      ]
    },

    {
      "name": "4. Recommendations",
      "item": [
        {
          "name": "List My Recommendations",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  const j = pm.response.json();",
            "  if (j.items && j.items.length > 0) { pm.environment.set('recommendation_id', j.items[0].id); }",
            "}"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{recommendations_url}}/api/v1/recommendations?page=1&page_size=20", "host": ["{{recommendations_url}}"], "path": ["api","v1","recommendations"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"}] } }
        },
        {
          "name": "Submit Feedback (Like)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"feedback\": \"like\"\n}" },
            "url": { "raw": "{{recommendations_url}}/api/v1/recommendations/{{recommendation_id}}/feedback", "host": ["{{recommendations_url}}"], "path": ["api","v1","recommendations","{{recommendation_id}}","feedback"] }
          }
        },
        {
          "name": "Dismiss Recommendation",
          "request": { "method": "DELETE", "url": { "raw": "{{recommendations_url}}/api/v1/recommendations/{{recommendation_id}}", "host": ["{{recommendations_url}}"], "path": ["api","v1","recommendations","{{recommendation_id}}"] } }
        },
        {
          "name": "Regenerate",
          "request": { "method": "POST", "url": { "raw": "{{recommendations_url}}/api/v1/recommendations/regenerate", "host": ["{{recommendations_url}}"], "path": ["api","v1","recommendations","regenerate"] } }
        }
      ]
    },

    {
      "name": "5. Catalog · Books",
      "description": "Libros del catálogo. List/Get son públicos; Create/Update/Delete requieren auth.",
      "item": [
        {
          "name": "Create Book",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) { pm.environment.set('book_id', pm.response.json().id); }"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Cien años de soledad\",\n  \"author\": \"Gabriel García Márquez\",\n  \"synopsis\": \"La saga de la familia Buendía\",\n  \"total_pages\": 471,\n  \"license\": \"copyrighted\",\n  \"language\": \"es\",\n  \"published_year\": 1967\n}" },
            "url": { "raw": "{{catalog_url}}/api/v1/books", "host": ["{{catalog_url}}"], "path": ["api","v1","books"] }
          }
        },
        {
          "name": "List Books",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{catalog_url}}/api/v1/books?page=1&page_size=20", "host": ["{{catalog_url}}"], "path": ["api","v1","books"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"},{"key":"search","value":"","disabled":true},{"key":"genre_id","value":"","disabled":true}] } }
        },
        {
          "name": "Get Book by ID",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{catalog_url}}/api/v1/books/{{book_id}}", "host": ["{{catalog_url}}"], "path": ["api","v1","books","{{book_id}}"] } }
        },
        {
          "name": "Update Book",
