    {
      "name": "7. Reading · Progress",
      "description": "Progreso de lectura del usuario. Todo requiere auth.",
      "item": [
        {
          "name": "Start/Update Reading",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"book_id\": \"{{book_id}}\",\n  \"current_page\": 1\n}" },
            "url": { "raw": "{{reading_url}}/api/v1/reading", "host": ["{{reading_url}}"], "path": ["api","v1","reading"] }
          }
        },
        {
          "name": "List My Progress",
          "request": { "method": "GET", "url": { "raw": "{{reading_url}}/api/v1/reading?status=reading", "host": ["{{reading_url}}"], "path": ["api","v1","reading"], "query": [{"key":"status","value":"reading","description":"reading|paused|finished|abandoned"}] } }
        },
        {
          "name": "Get Progress for Book",
          "request": { "method": "GET", "url": { "raw": "{{reading_url}}/api/v1/reading/{{book_id}}", "host": ["{{reading_url}}"], "path": ["api","v1","reading","{{book_id}}"] } }
        },
        {
          "name": "Update Progress",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"current_page\": 120,\n  \"total_time_min\": 45,\n  \"status\": \"reading\"\n}" },
            "url": { "raw": "{{reading_url}}/api/v1/reading/{{book_id}}", "host": ["{{reading_url}}"], "path": ["api","v1","reading","{{book_id}}"] }
          }
        },
        {
          "name": "Mark as Finished",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"finished\"\n}" },
            "url": { "raw": "{{reading_url}}/api/v1/reading/{{book_id}}", "host": ["{{reading_url}}"], "path": ["api","v1","reading","{{book_id}}"] }
          }
        },
        {
          "name": "Delete Progress",
          "request": { "method": "DELETE", "url": { "raw": "{{reading_url}}/api/v1/reading/{{book_id}}", "host": ["{{reading_url}}"], "path": ["api","v1","reading","{{book_id}}"] } }
        }
      ]
    },

    {
