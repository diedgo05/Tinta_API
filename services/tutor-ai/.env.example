# ─────────────────────────────────────────────────────────────
# Variables de entorno del servicio tutor-ai
# ─────────────────────────────────────────────────────────────
# En Railway estas se configuran en Settings → Variables.
# Este archivo sirve como plantilla y para desarrollo local.
# COPIAR a .env y llenar valores reales.
# ─────────────────────────────────────────────────────────────

# ── Servicio ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Base de datos ────────────────────────────────────────
# Usa el mismo Postgres compartido de Railway.
# El search_path=knowledge asegura que el esquema por defecto sea el nuevo.
DATABASE_URL=postgresql://user:pass@host:5432/tinta?search_path=knowledge,public

# ── JWT compartido con identity ──────────────────────────
# Copiar la CLAVE PÚBLICA RSA del servicio identity aquí.
# Debe incluir los saltos de línea reales (formato PEM completo).
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_ISSUER=tinta-identity

# ── LLM ──────────────────────────────────────────────────
# Ruta al modelo dentro del container (baked-in por el Dockerfile).
LLM_MODEL_PATH=/models/gemma-2-2b-it-q4_k_m.gguf
LLM_CONTEXT_SIZE=4096
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_N_THREADS=4
LLM_N_GPU_LAYERS=0

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# ── RAG ──────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_CHUNKS=3
MIN_SIMILARITY=0.3

# ── Uploads ──────────────────────────────────────────────
UPLOAD_DIR=/tmp/tinta-uploads
MAX_UPLOAD_SIZE_MB=20
